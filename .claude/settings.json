{
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(pnpm run *)",
      "Bash(yarn *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Read(src/**)",
      "Read(tests/**)",
      "Read(docs/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(credentials/**)",
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(git push --force*)",
      "Bash(git push origin main*)",
      "Bash(rm -rf*)",
      "Bash(sudo *)",
      "Bash(curl * | bash*)"
    ]
  }
}
